      }
  ],
  "诗名": [
    {
      "text": "细雨斜风作晓寒",
      "begin_time": 1000,
      "end_time": 2000
    }
  ],
  "作者": [
    {
      "text": "苏轼",
      "begin_time": 2000,
      "end_time": 3000
    }
  ],
  "诗句": [
    {
      "text": "细雨斜风作晓寒，淡烟疏柳媚晴滩。",
      "begin_time": 3000,
      "end_time": 4000
    },
    {
      "text": "入淮清洛渐漫漫。",
      "begin_time": 4000,
      "end_time": 5000
    },
    {
      "text": "雪沫乳花浮午盏，蓼茸蒿笋试春盘。",
      "begin_time": 5000,
      "end_time": 6000
    },
    {
      "text": "人间有味是清欢。",
      "begin_time": 6000,
      "end_time": 7000
    }
  ]
}